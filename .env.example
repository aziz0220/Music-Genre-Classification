# Kaggle API token (required for VGG19 model download)
# Get yours at https://www.kaggle.com/settings -> API -> Create New Token
KAGGLE_API_TOKEN=your_kaggle_api_token

# Frontend API URLs (for local development)
NEXT_PUBLIC_SVM_URL=http://localhost:5001/classify_genre
NEXT_PUBLIC_VGG_URL=http://localhost:5002/vgg19_service
