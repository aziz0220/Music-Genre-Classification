{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_SVM_URL": "https://music-genre-svm.onrender.com/classify_genre",
    "NEXT_PUBLIC_VGG_URL": "https://music-genre-vgg.onrender.com/vgg19_service",
    "NEXT_PUBLIC_SITE_URL": "https://music-genre-classify.vercel.app"
  },
  "rewrites": [
    {
      "source": "/api/svm/:path*",
      "destination": "https://music-genre-svm.onrender.com/:path*"
    },
    {
      "source": "/api/vgg/:path*",
      "destination": "https://music-genre-vgg.onrender.com/:path*"
    }
  ]
}
